generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sector {
  id                String    @id @default(uuid())
  name              String    @unique
  defaultSlaMinutes Int       @default(15)
  active            Boolean   @default(true)
  users             User[]
  projects          Project[]
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model User {
  id        String    @id @default(uuid())
  name      String
  phone     String    @unique
  role      String
  active    Boolean   @default(true)
  sectorId  String?
  sector    Sector?   @relation(fields: [sectorId], references: [id])
  projects  Project[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id                String      @id @default(uuid())
  name              String
  groupExternalId   String      @unique
  groupName         String
  responsibleUserId String
  sectorId          String?
  slaMinutes        Int         @default(15)
  active            Boolean     @default(true)

  responsibleUser   User        @relation(fields: [responsibleUserId], references: [id])
  sector            Sector?     @relation(fields: [sectorId], references: [id])
  messages          Message[]
  slaTickets        SlaTicket[]

  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

model Message {
  id                String    @id @default(uuid())
  projectId         String
  externalMessageId String    @unique
  senderPhone       String
  senderName        String?
  senderType        String
  body              String?
  sentAt            DateTime
  createdAt         DateTime  @default(now())

  project           Project   @relation(fields: [projectId], references: [id])
}

model SlaTicket {
  id                       String         @id @default(uuid())
  projectId                String
  openedMessageId          String
  openedAt                 DateTime
  deadlineAt               DateTime
  answeredMessageId        String?
  answeredAt               DateTime?
  status                   String
  delaySeconds             Int?
  warningNotificationSent  Boolean        @default(false)
  delayNotificationSent    Boolean        @default(false)
  privateNotificationSent  Boolean        @default(false)
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt

  project                  Project        @relation(fields: [projectId], references: [id])
  notifications            Notification[]
}

model Notification {
  id          String    @id @default(uuid())
  slaTicketId String
  userId      String
  type        String
  status      String
  payload     Json
  sentAt      DateTime?
  createdAt   DateTime  @default(now())

  slaTicket   SlaTicket @relation(fields: [slaTicketId], references: [id])
}

model PendingGroup {
  id              String   @id @default(uuid())
  groupExternalId String   @unique
  groupName       String?
  responsibleName String?
  lastMessageAt   DateTime
  createdAt       DateTime @default(now())
}